  // Stamp the ready signature at a PDF point (clicked point = top-left), width = 30% of page width.
  function stampSigAt(id: string, px: number, py: number) {
    if (!pendingSig || !curView) return;
    const pageW = curView.cssWidth / curView.scale; // page width in PDF points
    const w = pageW * 0.30, h = w / Math.max(0.01, pendingSig.aspect);
    let list = annots.get(id); if (!list) { list = []; annots.set(id, list); }
