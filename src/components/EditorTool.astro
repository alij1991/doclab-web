---
// Unified visual PDF editor — a two-pane studio: a thumbnail rail for
// navigation / selection / drag-reorder, and a large main view of the page
// you're working on (zoomable). Previews render with pdf.js on the main
// thread; the exported PDF is built by the pdf-lib worker (full fidelity).
// 100% client-side — nothing uploaded.
const STORE_URL = 'https://apps.microsoft.com/detail/9MV6R84RVKCZ';
---

<section class="editor-tool">
  <div id="dropzone" class="dropzone">
    <div class="dz-icon" aria-hidden="true">📄</div>
    <h3>Drop a PDF to start editing</h3>
    <p class="muted" style="margin: 2px 0 16px;">or</p>
    <button type="button" id="pickBtn" class="btn btn-primary">Choose a PDF</button>
    <input id="fileInput" type="file" accept="application/pdf,.pdf" class="visually-hidden" tabindex="-1" aria-hidden="true" />
    <div class="dz-caps" aria-hidden="true">
      <span>↕ Reorder</span><span>⟲ Rotate</span><span>🗑 Delete</span><span>＋ Add pages</span>
      <span>✎ Annotate</span><span>＃ Page numbers</span><span>💧 Watermark</span><span>🖼 To images</span>
    </div>
    <p class="muted dz-note">Everything runs in your browser — your file is never uploaded.</p>
  </div>

  <div id="workspace" hidden>
    <div class="ed-filebar">
      <div class="meta">
        <span class="name" id="fileName"></span>
        <span class="sub" id="fileSub"></span>
      </div>
      <button type="button" id="resetBtn" class="btn-ghost btn-sm" aria-label="Open a different file">Open another</button>
    </div>

    <div id="warn" class="warn-strip" hidden role="note">
      <span class="warn-ico" aria-hidden="true">⚠</span>
      <span class="warn-msg">Tagged PDF — editing here may drop accessibility tags. For tag-preserving edits, use the DocLab desktop app.</span>
      <button type="button" id="warnDismiss" class="warn-x" aria-label="Dismiss accessibility notice">×</button>
    </div>

    <div class="editor-bar" role="toolbar" aria-label="Editor actions">
      <div class="bar-group selinfo">
        <span id="selCount" class="sc">No pages selected</span>
        <button type="button" id="selectAllBtn" class="linklike">All</button>
        <button type="button" id="clearSelBtn" class="linklike" disabled>None</button>
      </div>
      <span class="bar-div"></span>
      <div class="bar-group" aria-label="Pages">
        <span class="grp-label">Pages</span>
        <button type="button" id="addBtn" class="btn-icon" title="Add pages from another PDF or from images">＋ Add pages</button>
        <input id="addInput" type="file" accept="application/pdf,.pdf,image/jpeg,image/png" multiple class="visually-hidden" tabindex="-1" aria-hidden="true" />
        <button type="button" id="rotLBtn" class="btn-icon" title="Rotate left (selected or current page)">⟲ Rotate left</button>
        <button type="button" id="rotRBtn" class="btn-icon" title="Rotate right (selected or current page)">⟳ Rotate right</button>
        <button type="button" id="dupBtn" class="btn-icon" title="Duplicate (selected or current page)">⧉ Duplicate</button>
        <button type="button" id="extractBtn" class="btn-icon" title="Extract selected pages to a new PDF" disabled>⬇ Extract</button>
        <button type="button" id="delBtn" class="btn-icon danger" title="Delete (selected or current page)">🗑 Delete</button>
      </div>
      <span class="bar-div"></span>
      <div class="bar-group" aria-label="Tools">
        <span class="grp-label">Tools</span>
        <button type="button" id="annBtn" class="btn-icon" title="Annotate: draw, highlight, text, shapes">✎ Annotate</button>
        <button type="button" id="signBtn" class="btn-icon" title="Sign: draw, type, or upload a signature">✍ Sign</button>
        <button type="button" id="numBtn" class="btn-icon" title="Add page numbers">＃ Page numbers</button>
        <button type="button" id="wmBtn" class="btn-icon" title="Add a watermark">💧 Watermark</button>
        <button type="button" id="imgBtn" class="btn-icon" title="Export pages as images">🖼 To images</button>
      </div>
      <div class="bar-right">
        <button type="button" id="downloadBtn" class="btn btn-primary btn-sm">⤓ Download PDF</button>
      </div>
    </div>

    <div class="studio" id="studio">
      <aside id="rail" class="rail" aria-label="Pages — click to open, drag to reorder"></aside>

      <section class="stage">
        <div id="stageScroll" class="stage-scroll">
          <div id="pageWrap" class="page-wrap" hidden>
            <canvas id="bigCanvas" role="img" aria-label="Current PDF page preview"></canvas>
            <canvas id="annotCanvas" class="annot-canvas" role="img" aria-label="Annotation and signature layer"></canvas>
            <div id="textLayer" class="text-layer"></div>
            <div id="annTip" class="annot-tip" hidden aria-hidden="true">↖ Switch to <strong>Select / Move</strong> to move or resize this</div>
          </div>
          <p id="stageEmpty" class="stage-empty">Loading page…</p>
        </div>
        <div class="stage-bar">
          <div class="nav">
            <button type="button" id="prevBtn" class="btn-icon" aria-label="Previous page">‹</button>
            <span id="pageInd" class="pageind">—</span>
            <button type="button" id="nextBtn" class="btn-icon" aria-label="Next page">›</button>
          </div>
          <span class="hint">Click a page to open · Shift-range · Ctrl/⌘ to add · drag to reorder</span>
          <div class="zoom">
            <button type="button" id="zoomOutBtn" class="btn-icon" aria-label="Zoom out">−</button>
            <span id="zoomVal" class="zval">100%</span>
            <button type="button" id="zoomInBtn" class="btn-icon" aria-label="Zoom in">+</button>
            <button type="button" id="zoomFitBtn" class="btn-icon" title="Fit whole page">Fit</button>
          </div>
        </div>
      </section>

      <aside id="toolPanel" class="toolpanel" hidden aria-label="Tool options">
        <div class="tp-section" data-tp="ann" hidden>
          <div class="tp-head"><strong>Annotate</strong><button type="button" class="tp-close" data-close aria-label="Close">✕</button></div>
          <div class="atools" role="group" aria-label="Annotation tool">
            <button type="button" class="atool atool-select" data-atool="select">↖ Select / Move</button>
            <button type="button" class="atool active" data-atool="pen">✏ Draw</button>
            <button type="button" class="atool" data-atool="highlight">🖍 Highlight</button>
            <button type="button" class="atool" data-atool="text">T Text</button>
            <button type="button" class="atool" data-atool="rect">▭ Box</button>
            <button type="button" class="atool" data-atool="line">／ Line</button>
          </div>
          <p class="muted" id="annHint" style="font-size: 12px; margin: 0;">Draw on the page. To move or resize, switch to <strong>↖ Select / Move</strong>.</p>
          <div class="tp-field" id="annColorField">Color
            <span class="swatches" id="annSwatches">
              <button type="button" class="sw active" data-color="0,0,0" style="background:#111" aria-label="Black"></button>
              <button type="button" class="sw" data-color="0.9,0.12,0.12" style="background:#e21f1f" aria-label="Red"></button>
              <button type="button" class="sw" data-color="0.13,0.33,0.9" style="background:#2154e6" aria-label="Blue"></button>
              <button type="button" class="sw" data-color="0.12,0.6,0.22" style="background:#1f9b38" aria-label="Green"></button>
              <button type="button" class="sw" data-color="1,0.84,0" style="background:#ffd700" aria-label="Yellow"></button>
              <button type="button" class="sw" data-color="1,1,1" style="background:#fff" aria-label="White"></button>
            </span>
          </div>
          <label class="tp-field" id="annWidthField">Thickness <input id="annWidth" type="range" min="1" max="12" value="3" /></label>
          <label class="tp-field" id="annSizeField" hidden>Text size <input id="annTextSize" type="number" min="6" max="96" value="16" class="text-input" /></label>
          <div class="tp-row">
            <button type="button" id="annUndo" class="btn btn-ghost btn-sm" style="flex:1;">Undo</button>
            <button type="button" id="annClear" class="btn btn-ghost btn-sm" style="flex:1;">Clear page</button>
          </div>
          <p class="muted" style="font-size: 12px; margin: 0;">Annotations bake into the PDF on Download / Extract / To-images.</p>
        </div>

        <div class="tp-section" data-tp="sign" hidden>
          <div class="tp-head"><strong>Sign</strong><button type="button" class="tp-close" data-close aria-label="Close">✕</button></div>
          <div class="atools" role="group" aria-label="Signature mode">
            <button type="button" class="atool active" data-sigmode="draw">✏ Draw</button>
            <button type="button" class="atool" data-sigmode="type">T Type</button>
            <button type="button" class="atool" data-sigmode="upload">⬆ Upload</button>
          </div>
          <div id="sigDrawWrap" class="sig-mode">
            <canvas id="sigPad" class="sig-pad" width="520" height="200" role="img" aria-label="Signature drawing pad"></canvas>
            <p class="muted" style="font-size:12px;margin:0;">Draw your signature above with the mouse or your finger.</p>
          </div>
          <div id="sigTypeWrap" class="sig-mode" hidden>
            <label class="tp-field">Your name <input id="sigText" type="text" maxlength="60" placeholder="Jane Doe" class="text-input" /></label>
            <label class="tp-field">Style
              <select id="sigFont" class="text-input">
                <option value='"Segoe Script","Brush Script MT",cursive' selected>Script</option>
                <option value='"Lucida Handwriting","Apple Chancery",cursive'>Handwriting</option>
                <option value='"Comic Sans MS","Comic Sans",cursive'>Casual</option>
              </select>
            </label>
            <canvas id="sigTypePreview" class="sig-pad" width="520" height="140" role="img" aria-label="Typed signature preview"></canvas>
          </div>
          <div id="sigUploadWrap" class="sig-mode" hidden>
            <button type="button" id="sigUploadBtn" class="btn btn-ghost btn-sm">Choose PNG or JPG…</button>
            <input id="sigUploadInput" type="file" accept="image/png,image/jpeg" class="visually-hidden" tabindex="-1" aria-hidden="true" />
            <canvas id="sigUploadPreview" class="sig-pad" width="520" height="160" hidden role="img" aria-label="Uploaded signature preview"></canvas>
          </div>
          <div class="tp-row">
            <button type="button" id="sigClear" class="btn btn-ghost btn-sm" style="flex:1;">Clear</button>
            <button type="button" id="sigUse" class="btn btn-primary btn-sm" style="flex:1;">Use signature</button>
          </div>
          <label class="tp-check"><input id="sigEveryPage" type="checkbox" /> Place on every page</label>
          <p class="muted" id="sigHint" style="font-size: 12px; margin: 0;">Create a signature, then click on the page to place it. Drag it or a corner to move / resize.</p>
        </div>

        <div class="tp-section" data-tp="num" hidden>
          <div class="tp-head"><strong>Page numbers</strong><button type="button" class="tp-close" data-close aria-label="Close">✕</button></div>
          <label class="tp-field">Position
            <select id="numPos" class="text-input">
              <option value="bottom-center" selected>Bottom center</option>
              <option value="bottom-right">Bottom right</option>
              <option value="bottom-left">Bottom left</option>
              <option value="top-center">Top center</option>
              <option value="top-right">Top right</option>
              <option value="top-left">Top left</option>
            </select>
          </label>
          <div class="tp-row">
            <label class="tp-field">Start at <input id="numStart" type="number" min="0" value="1" class="text-input" /></label>
            <label class="tp-field">Size <input id="numSize" type="number" min="6" max="48" value="11" class="text-input" /></label>
          </div>
          <label class="tp-check"><input id="numTotal" type="checkbox" /> Show “n of N”</label>
          <button type="button" id="numApply" class="btn btn-primary tp-apply">Add page numbers</button>
        </div>

        <div class="tp-section" data-tp="wm" hidden>
          <div class="tp-head"><strong>Watermark</strong><button type="button" class="tp-close" data-close aria-label="Close">✕</button></div>
          <label class="tp-field">Text <input id="wmText" type="text" value="DRAFT" maxlength="80" class="text-input" /></label>
          <label class="tp-field">Size <input id="wmSize" type="number" min="0" max="200" value="0" placeholder="auto" class="text-input" /></label>
          <label class="tp-field">Opacity <input id="wmOpacity" type="range" min="5" max="80" value="18" /></label>
          <button type="button" id="wmApply" class="btn btn-primary tp-apply">Add watermark</button>
        </div>

        <div class="tp-section" data-tp="img" hidden>
          <div class="tp-head"><strong>Export as images</strong><button type="button" class="tp-close" data-close aria-label="Close">✕</button></div>
          <label class="tp-field">Format
            <select id="imgFormat" class="text-input">
              <option value="png" selected>PNG</option>
              <option value="jpg">JPG</option>
            </select>
          </label>
          <label class="tp-field">Quality
            <select id="imgQuality" class="text-input">
              <option value="1240">Standard</option>
              <option value="2000" selected>High</option>
            </select>
          </label>
          <p class="muted" style="font-size: 12.5px; margin: 2px 0 0;">Multiple pages download as a .zip.</p>
          <button type="button" id="imgApply" class="btn btn-primary tp-apply">Export images</button>
        </div>
      </aside>
    </div>
  </div>

  <p id="status" class="status" role="status" aria-live="polite"></p>

  <div class="trust"><strong>100% private.</strong> Your PDF is opened, edited, and exported right here in your browser — it is never uploaded.</div>
  <p class="upsell muted" style="font-size: 13.5px;">
    Need OCR, redaction, signing, or to edit text? <a href={STORE_URL} target="_blank" rel="noopener">Get the free DocLab desktop app →</a>
  </p>
</section>

<script>
  import { pdfApi } from '../lib/pdfClient';
  import { openForThumbs, type ThumbDoc, type PageView } from '../lib/pdfThumbs';
  import type { Annot } from '../lib/pdf.worker';

  const THUMB_PX = 180;
  const $ = (id: string) => document.getElementById(id)!;
  const dropzone = $('dropzone');
  const pickBtn = $('pickBtn') as HTMLButtonElement;
  const fileInput = $('fileInput') as HTMLInputElement;
  const workspace = $('workspace');
  const fileNameEl = $('fileName');
  const fileSubEl = $('fileSub');
  const warnEl = $('warn');
  const rail = $('rail');
  const stageScroll = $('stageScroll');
  const bigCanvas = $('bigCanvas') as HTMLCanvasElement;
  const stageEmpty = $('stageEmpty');
  const pageInd = $('pageInd');
  const zoomVal = $('zoomVal');
  const selCountEl = $('selCount');
  const statusEl = $('status');
  const downloadBtn = $('downloadBtn') as HTMLButtonElement;
  const selectAllBtn = $('selectAllBtn') as HTMLButtonElement;
  const clearSelBtn = $('clearSelBtn') as HTMLButtonElement;
  const rotLBtn = $('rotLBtn') as HTMLButtonElement;
  const rotRBtn = $('rotRBtn') as HTMLButtonElement;
  const dupBtn = $('dupBtn') as HTMLButtonElement;
  const extractBtn = $('extractBtn') as HTMLButtonElement;
  const delBtn = $('delBtn') as HTMLButtonElement;
  const resetBtn = $('resetBtn') as HTMLButtonElement;
  const addBtn = $('addBtn') as HTMLButtonElement;
  const addInput = $('addInput') as HTMLInputElement;
  const prevBtn = $('prevBtn') as HTMLButtonElement;
  const nextBtn = $('nextBtn') as HTMLButtonElement;
  const zoomInBtn = $('zoomInBtn') as HTMLButtonElement;
  const zoomOutBtn = $('zoomOutBtn') as HTMLButtonElement;
  const zoomFitBtn = $('zoomFitBtn') as HTMLButtonElement;
  const pageWrap = $('pageWrap');
  const annotCanvas = $('annotCanvas') as HTMLCanvasElement;
  const textLayer = $('textLayer');
  const annTip = $('annTip');

  interface Tile { sourceId: string; src: number; rotate: number; }

  let fileName = '';
  const sources = new Map<string, { bytes: ArrayBuffer; doc: ThumbDoc }>();
  const docFor = (id: string): ThumbDoc | undefined => sources.get(id)?.doc;
  const newId = (p: string) => p + crypto.randomUUID().slice(0, 8);
  const state = new Map<string, Tile>();
  const els = new Map<string, HTMLElement>();
  const rendered = new Set<string>();
  const selected = new Set<string>();
  let anchor: string | null = null;
  let activeId: string | null = null;
  let zoom = 1;
  let renderChain: Promise<void> = Promise.resolve();
  let bigToken = 0;
  let observer: IntersectionObserver | null = null;

  // annotations: per-tile list, stored in PDF user-space coordinates
  const annots = new Map<string, Annot[]>();
  let curView: PageView | null = null; // converters for the active page render
  let annTool: 'select' | 'pen' | 'highlight' | 'text' | 'rect' | 'line' = 'pen';
  let annRgb: [number, number, number] = [0, 0, 0];
  let annStroke = 3;
  let annTextSize = 16;
  let annotateMode = false;
  const actx = annotCanvas.getContext('2d');
  // selection / move / resize of an existing annotation (select tool)
  let selAnnot: Annot | null = null;
  type Box = { x: number; y: number; w: number; h: number };
  let drag: { mode: 'move' | 'resize'; handle: string; snap: Annot; obox: Box; startPdf: [number, number] } | null = null;
  const measureCtx = document.createElement('canvas').getContext('2d');

  // --- signature feature state ---
  let sigMode: 'draw' | 'type' | 'upload' = 'draw';
  let pendingSig: { bytes: Uint8Array; aspect: number } | null = null; // created sig, awaiting placement
  let placingSig = false; // true while the Sign panel has a ready signature → click page to stamp
  // Decoded-image cache for painting image annots on the overlay, keyed by Annot.key.
  // Kept OFF the Annot so cloneAnnot / duplicate (which deep-copy) stay valid + serializable.
  const imgCache = new Map<string, HTMLImageElement>();
  const imgPending = new Set<string>(); // keys currently decoding (avoid duplicate loads)
  const blobUrls = new Set<string>(); // download object-URLs, revoked on teardown as a backstop

  function setStatus(msg: string, kind: '' | 'ok' | 'err' = '') {
    statusEl.textContent = msg;
    statusEl.className = 'status' + (kind ? ' ' + kind : '');
  }
  function shortError(e: unknown): string {
    const s = e instanceof Error ? e.message : String(e);
    return s.length > 160 ? s.slice(0, 159) + '…' : s;
  }
  const orderedIds = (): string[] => [...rail.querySelectorAll<HTMLElement>('.ptile')].map((t) => t.dataset.id!);
  const selectedOrdered = (): string[] => orderedIds().filter((id) => selected.has(id));
  const targetIds = (): string[] => (selected.size ? selectedOrdered() : activeId ? [activeId] : []);
  const tileCount = (): number => rail.querySelectorAll('.ptile').length;

  function renumber() {
    rail.querySelectorAll<HTMLElement>('.ptile').forEach((t, i) => {
      const pos = t.querySelector('.pos');
      if (pos) pos.textContent = String(i + 1);
    });
    const n = tileCount();
    fileSubEl.textContent = `${n} page${n === 1 ? '' : 's'}`;
    updateButtons();
    updatePageInd();
  }
  function updatePageInd() {
    const ids = orderedIds();
    const idx = activeId ? ids.indexOf(activeId) : -1;
    pageInd.textContent = idx >= 0 ? `Page ${idx + 1} of ${ids.length}` : '—';
    prevBtn.disabled = idx <= 0;
    nextBtn.disabled = idx < 0 || idx >= ids.length - 1;
  }
  function updateButtons() {
    const n = tileCount();
    const hasTarget = targetIds().length > 0 && n > 0;
    rotLBtn.disabled = !hasTarget;
    rotRBtn.disabled = !hasTarget;
    dupBtn.disabled = !hasTarget;
    delBtn.disabled = !hasTarget;
    extractBtn.disabled = selected.size === 0;
    downloadBtn.disabled = n === 0;
  }
  function refreshSelectionUI() {
    for (const [id, el] of els) el.classList.toggle('sel', selected.has(id));
    const n = selected.size;
    selCountEl.textContent = n === 0 ? 'No pages selected' : `${n} page${n === 1 ? '' : 's'} selected`;
    clearSelBtn.disabled = n === 0;
    updateButtons();
  }
  function updateRotBadge(id: string) {
    const el = els.get(id);
    const s = state.get(id);
    if (!el || !s) return;
    const badge = el.querySelector('.rotbadge') as HTMLElement | null;
    if (!badge) return;
    const r = ((s.rotate % 360) + 360) % 360;
    if (r === 0) badge.hidden = true;
    else { badge.hidden = false; badge.textContent = `${r}°`; }
  }

  function queueRender(id: string) {
    renderChain = renderChain.then(async () => {
      const el = els.get(id);
      const s = state.get(id);
      const doc = s ? docFor(s.sourceId) : undefined;
      if (!el || !s || !doc) return;
      const canvas = el.querySelector('canvas') as HTMLCanvasElement | null;
      if (!canvas) return;
      try {
        await doc.render(s.src, canvas, THUMB_PX, s.rotate);
        el.classList.add('thumb-ready');
      } catch (e) {
        el.classList.remove('thumb-ready');
        console.error('[thumb render]', e);
      }
    });
  }

  async function renderBig() {
    const s = activeId ? state.get(activeId) : undefined;
    const doc = s ? docFor(s.sourceId) : undefined;
    if (!s || !doc) {
      pageWrap.hidden = true;
      curView = null;
      stageEmpty.hidden = false;
      stageEmpty.textContent = 'No page';
      return;
    }
    const token = ++bigToken;
    const availW = Math.max(160, stageScroll.clientWidth - 44);
    const availH = Math.max(160, stageScroll.clientHeight - 44);
    const dpr = window.devicePixelRatio || 1;
    try {
      const pv = await doc.renderFit(s.src, bigCanvas, availW, availH, zoom, s.rotate, dpr);
      if (token !== bigToken) return; // a newer render superseded this one
      curView = pv;
      pageWrap.hidden = false;
      stageEmpty.hidden = true;
      // size the annotation overlay to match the page canvas, then paint
      const dprc = Math.min(Math.max(dpr, 1), 2);
      annotCanvas.width = Math.max(1, Math.round(pv.cssWidth * dprc));
      annotCanvas.height = Math.max(1, Math.round(pv.cssHeight * dprc));
      annotCanvas.style.width = Math.round(pv.cssWidth) + 'px';
      annotCanvas.style.height = Math.round(pv.cssHeight) + 'px';
      redrawOverlay();
    } catch (e) {
      console.error('[big render]', e);
      if (token === bigToken) { pageWrap.hidden = true; stageEmpty.hidden = false; stageEmpty.textContent = 'Preview unavailable'; }
    }
  }

  function curAnnots(): Annot[] {
    if (!activeId) return [];
    let list = annots.get(activeId);
    if (!list) { list = []; annots.set(activeId, list); }
    return list;
  }

  // Paint committed annotations (+ an optional in-progress one) on the overlay,
  // converting PDF coords back to screen via the active page's converters.
  function redrawOverlay(preview?: Annot) {
    if (!actx) return;
    const dprc = annotCanvas.width / Math.max(1, parseFloat(annotCanvas.style.width));
    actx.setTransform(dprc, 0, 0, dprc, 0, 0);
    actx.clearRect(0, 0, annotCanvas.width, annotCanvas.height);
    if (!curView) return;
    const list = activeId ? annots.get(activeId) ?? [] : [];
    for (const a of list) paintAnnot(a);
    if (preview) paintAnnot(preview);
    if (selAnnot && !preview) drawSelectionChrome();
  }

  function paintAnnot(a: Annot) {
    if (!actx || !curView) return;
    const sc = curView.scale;
    const css = (px: number, py: number) => curView!.toView(px, py);
    const col = (rgb: [number, number, number], alpha = 1) =>
      `rgba(${Math.round(rgb[0] * 255)},${Math.round(rgb[1] * 255)},${Math.round(rgb[2] * 255)},${alpha})`;
    if (a.kind === 'ink') {
      actx.strokeStyle = col(a.rgb);
      actx.lineWidth = a.width * sc;
      actx.lineJoin = 'round';
      actx.lineCap = 'round';
      actx.beginPath();
      for (let i = 0; i + 1 < a.points.length; i += 2) {
        const [x, y] = css(a.points[i]!, a.points[i + 1]!);
        if (i === 0) actx.moveTo(x, y);
        else actx.lineTo(x, y);
      }
      actx.stroke();
    } else if (a.kind === 'line') {
      actx.strokeStyle = col(a.rgb);
      actx.lineWidth = a.width * sc;
      actx.lineCap = 'round';
      const [x1, y1] = css(a.x1, a.y1);
      const [x2, y2] = css(a.x2, a.y2);
      actx.beginPath();
      actx.moveTo(x1, y1);
      actx.lineTo(x2, y2);
      actx.stroke();
    } else if (a.kind === 'rect' || a.kind === 'highlight') {
      const [x1, y1] = css(a.x, a.y);
      const [x2, y2] = css(a.x + a.w, a.y + a.h);
      const rx = Math.min(x1, x2);
      const ry = Math.min(y1, y2);
      const rw = Math.abs(x2 - x1);
      const rh = Math.abs(y2 - y1);
      if (a.kind === 'highlight') {
        actx.fillStyle = col(a.rgb, a.opacity);
        actx.fillRect(rx, ry, rw, rh);
      } else {
        actx.strokeStyle = col(a.rgb);
        actx.lineWidth = a.width * sc;
        actx.strokeRect(rx, ry, rw, rh);
      }
    } else if (a.kind === 'text') {
      const [x, y] = css(a.x, a.y);
      actx.fillStyle = col(a.rgb);
      actx.font = `${a.size * sc}px Helvetica, Arial, sans-serif`;
      actx.textBaseline = 'alphabetic';
      actx.fillText(a.text, x, y);
    } else if (a.kind === 'image') {
      const [x1, y1] = css(a.x, a.y);
      const [x2, y2] = css(a.x + a.w, a.y + a.h);
      const rx = Math.min(x1, x2), ry = Math.min(y1, y2);
      const rw = Math.abs(x2 - x1), rh = Math.abs(y2 - y1);
      const img = getAnnotImage(a);
      if (img) actx.drawImage(img, rx, ry, rw, rh);
      else { actx.save(); actx.fillStyle = 'rgba(124,108,255,0.10)'; actx.fillRect(rx, ry, rw, rh); actx.restore(); }
    }
  }

  // Decode an image annot's PNG bytes to an <img> for canvas painting, cached by key.
  // Async on first sight: kicks off a load, then repaints when ready (deferred paint).
  function getAnnotImage(a: Extract<Annot, { kind: 'image' }>): HTMLImageElement | null {
    const hit = imgCache.get(a.key);
    if (hit) return hit.complete && hit.naturalWidth ? hit : null;
    if (imgPending.has(a.key)) return null;
    imgPending.add(a.key);
    const url = URL.createObjectURL(new Blob([a.data as BlobPart], { type: 'image/png' }));
    const img = new Image();
    img.onload = () => { imgCache.set(a.key, img); imgPending.delete(a.key); URL.revokeObjectURL(url); redrawOverlay(); };
    img.onerror = () => { imgPending.delete(a.key); URL.revokeObjectURL(url); };
    // Clear a stalled decode so a corrupt image can't pin the key forever.
    setTimeout(() => {
      if (imgPending.has(a.key)) { imgPending.delete(a.key); imgCache.delete(a.key); img.onload = img.onerror = null; img.src = ''; URL.revokeObjectURL(url); }
    }, 8000);
    img.src = url;
    return null;
  }

  function setActive(id: string | null) {
    activeId = id;
    selAnnot = null;
    if (curTool === 'sign' && placingSig) annotCanvas.style.cursor = 'copy'; // keep multi-page placement armed
    for (const [tid, el] of els) el.classList.toggle('active', tid === id);
    if (id) els.get(id)?.scrollIntoView({ block: 'nearest', inline: 'nearest' });
    updatePageInd();
    renderBig();
  }

  // selection
  function selectOnly(id: string) { selected.clear(); selected.add(id); anchor = id; refreshSelectionUI(); }
  function toggle(id: string) { selected.has(id) ? selected.delete(id) : selected.add(id); anchor = id; refreshSelectionUI(); }
  function selectRange(toId: string) {
    const ids = orderedIds();
    const a = anchor ? ids.indexOf(anchor) : -1;
    const b = ids.indexOf(toId);
    if (a < 0 || b < 0) return selectOnly(toId);
    selected.clear();
    const [lo, hi] = a < b ? [a, b] : [b, a];
    for (let i = lo; i <= hi; i++) selected.add(ids[i]!);
    refreshSelectionUI();
  }

  function buildTile(id: string): HTMLElement {
    const s = state.get(id)!;
    const el = document.createElement('div');
    el.className = 'ptile';
    el.dataset.id = id;
    el.setAttribute('draggable', 'true');

    const pos = document.createElement('span');
    pos.className = 'pos';
    const rot = document.createElement('span');
    rot.className = 'rotbadge';
    rot.hidden = true;
    const check = document.createElement('span');
    check.className = 'check';
    check.textContent = '✓';
    const thumb = document.createElement('div');
    thumb.className = 'thumb';
    const canvas = document.createElement('canvas');
    const ph = document.createElement('span');
    ph.className = 'ph';
    ph.textContent = `Page ${s.src + 1}`;
    thumb.append(canvas, ph);

    el.append(pos, rot, check, thumb);
    els.set(id, el);
    observer?.observe(el);

    el.addEventListener('click', (e) => {
      const me = e as MouseEvent;
      if (me.shiftKey) selectRange(id);
      else if (me.ctrlKey || me.metaKey) toggle(id);
      else selectOnly(id);
      setActive(id);
    });
    el.addEventListener('dragstart', (e) => {
      el.classList.add('dragging');
      (e as DragEvent).dataTransfer?.setData('text/plain', id);
      if ((e as DragEvent).dataTransfer) (e as DragEvent).dataTransfer!.effectAllowed = 'move';
    });
    el.addEventListener('dragend', () => { el.classList.remove('dragging'); renumber(); });
    return el;
  }

  function getDragAfter(x: number, y: number): Element | null {
    const tiles = [...rail.querySelectorAll('.ptile:not(.dragging)')];
    let closest: Element | null = null;
    let dist = Infinity;
    let before = true;
    for (const t of tiles) {
      const r = t.getBoundingClientRect();
      const cx = r.left + r.width / 2;
      const cy = r.top + r.height / 2;
      const d = Math.hypot(x - cx, y - cy);
      if (d < dist) { dist = d; closest = t; before = (y < cy) || (Math.abs(y - cy) < r.height / 2 && x < cx); }
    }
    if (!closest) return null;
    return before ? closest : closest.nextElementSibling;
  }
  rail.addEventListener('dragover', (e) => {
    e.preventDefault();
    const dragging = rail.querySelector('.ptile.dragging') as HTMLElement | null;
    if (!dragging) return;
    if ((e as DragEvent).dataTransfer) (e as DragEvent).dataTransfer!.dropEffect = 'move';
    const after = getDragAfter((e as DragEvent).clientX, (e as DragEvent).clientY);
    if (after == null) rail.appendChild(dragging);
    else if (after !== dragging) rail.insertBefore(dragging, after);
  });
  rail.addEventListener('drop', (e) => e.preventDefault());

  // operations
  function rotateIds(ids: string[], delta: number) {
    for (const id of ids) {
      const s = state.get(id);
      if (!s) continue;
      s.rotate = (((s.rotate + delta) % 360) + 360) % 360;
      updateRotBadge(id);
      queueRender(id);
    }
    if (activeId && ids.includes(activeId)) renderBig();
  }
  function deleteIds(ids: string[]) {
    if (ids.length === 0) return;
    if (ids.length >= tileCount()) { setStatus('Keep at least one page.', 'err'); return; }
    const ordered = orderedIds();
    const firstIdx = Math.min(...ids.map((id) => ordered.indexOf(id)).filter((i) => i >= 0));
    const removing = new Set(ids);
    for (const id of ids) {
      const el = els.get(id);
      if (el) { observer?.unobserve(el); el.remove(); }
      els.delete(id);
      state.delete(id);
      rendered.delete(id);
      selected.delete(id);
      annots.delete(id);
    }
    anchor = null;
    renumber();
    refreshSelectionUI();
    if (activeId && removing.has(activeId)) {
      const left = orderedIds();
      setActive(left[Math.min(firstIdx, left.length - 1)] ?? left[0] ?? null);
    }
    setStatus('');
  }
  function duplicateIds(ids: string[]) {
    const ordered = orderedIds().filter((id) => ids.includes(id));
    if (ordered.length === 0) return;
    for (const id of ordered) {
      const s = state.get(id)!;
      const el = els.get(id)!;
      const dupId = newId('d');
      state.set(dupId, { sourceId: s.sourceId, src: s.src, rotate: s.rotate });
      const srcAnn = annots.get(id);
      if (srcAnn && srcAnn.length) annots.set(dupId, srcAnn.map(cloneAnnot));
      el.after(buildTile(dupId));
      rendered.add(dupId);
      queueRender(dupId);
    }
    renumber();
    setStatus(`Duplicated ${ordered.length} page${ordered.length === 1 ? '' : 's'}.`, 'ok');
  }

  function download(out: Uint8Array, name: string, mime = 'application/pdf') {
    const ab = new ArrayBuffer(out.byteLength);
    new Uint8Array(ab).set(out);
    const url = URL.createObjectURL(new Blob([ab], { type: mime }));
    blobUrls.add(url);
    const a = document.createElement('a');
    a.href = url;
    a.download = name;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => { URL.revokeObjectURL(url); blobUrls.delete(url); }, 2000);
  }
  const baseName = () => fileName.replace(/\.pdf$/i, '') || 'document';

  async function exportPages(ids: string[], suffix: string, label: string) {
    if (ids.length === 0) return;
    downloadBtn.disabled = true;
    extractBtn.disabled = true;
    setStatus('Building your PDF…');
    try {
      const out = await composeBaked(ids);
      download(out, `${baseName()}-${suffix}.pdf`);
      setStatus(`${label} — your download should start automatically.`, 'ok');
    } catch (e) {
      console.error(e);
      setStatus(shortError(e), 'err');
    } finally {
      updateButtons();
    }
  }

  // zoom
  function setZoom(z: number) {
    zoom = Math.min(5, Math.max(0.25, z));
    zoomVal.textContent = Math.round(zoom * 100) + '%';
    renderBig();
  }

  function teardown() {
    observer?.disconnect();
    observer = null;
    for (const s of sources.values()) s.doc.destroy();
    sources.clear();
    state.clear();
    els.clear();
    rendered.clear();
    selected.clear();
    anchor = null;
    activeId = null;
    zoom = 1;
    zoomVal.textContent = '100%';
    rail.replaceChildren();
    pageWrap.hidden = true;
    curView = null;
    annots.clear();
    imgCache.clear(); imgPending.clear(); // blob URLs already revoked on load
    for (const u of blobUrls) URL.revokeObjectURL(u); // revoke any not-yet-expired download URLs
    blobUrls.clear();
    pendingSig = null; placingSig = false;
    sigPadCtx?.clearRect(0, 0, sigPad.width, sigPad.height);
    selAnnot = null;
    drag = null;
    textLayer.replaceChildren();
    renderChain = Promise.resolve();
    refreshSelectionUI();
  }
  function reset() {
    teardown();
    fileName = '';
    workspace.hidden = true;
    dropzone.hidden = false;
    document.body.classList.remove('doc-open');
    warnEl.hidden = true;
    fileInput.value = '';
    setStatus('');
  }

  async function installSingleSource(buf: ArrayBuffer, name: string, tagged: boolean): Promise<boolean> {
    teardown();
    let doc: ThumbDoc;
    try { doc = await openForThumbs(buf.slice(0)); }
    catch (e) { console.error(e); setStatus("Couldn't read this PDF for preview — try the desktop app.", 'err'); return false; }

    const sid = newId('s');
    sources.set(sid, { bytes: buf, doc });
    fileName = name;
    fileNameEl.textContent = name;
    warnEl.hidden = !tagged; // message lives in markup so the dismiss button survives

    observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const id = (entry.target as HTMLElement).dataset.id;
          if (id && !rendered.has(id)) { rendered.add(id); queueRender(id); }
        }
      },
      { root: rail, rootMargin: '400px' },
    );

    const ids = appendSourcePages(sid, doc.pageCount);
    dropzone.hidden = true;
    workspace.hidden = false;
    document.body.classList.add('doc-open');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    stageEmpty.textContent = 'Loading page…';
    setActive(ids[0] ?? null);
    if (ids[0]) selectOnly(ids[0]);
    return true;
  }

  async function loadFile(file: File) {
    if (file.type !== 'application/pdf' && !file.name.toLowerCase().endsWith('.pdf')) {
      setStatus('Please choose a PDF file.', 'err');
      return;
    }
    setStatus('Opening…');
    const buf = await file.arrayBuffer();
    const info = await pdfApi().analyze(buf.slice(0));
    if (info.encrypted || info.pages === 0) {
      setStatus("Can't open this PDF (encrypted or damaged) — try the desktop app.", 'err');
      return;
    }
    if (await installSingleSource(buf, file.name, info.tagged)) setStatus('');
  }

  const toAB = (u: Uint8Array): ArrayBuffer => { const ab = new ArrayBuffer(u.byteLength); new Uint8Array(ab).set(u); return ab; };

  function currentSourcesAndPages(ids: string[]) {
    const usedIds = [...new Set(ids.map((id) => state.get(id)!.sourceId))];
    const srcArr = usedIds.map((sid) => ({ id: sid, bytes: sources.get(sid)!.bytes.slice(0) }));
    const pages = ids.map((id) => { const s = state.get(id)!; return { sourceId: s.sourceId, index: s.src, rotate: s.rotate }; });
    return { srcArr, pages };
  }

  // Compose the given tiles into one PDF and bake any annotations on them.
  async function composeBaked(ids: string[]): Promise<Uint8Array> {
    const { srcArr, pages } = currentSourcesAndPages(ids);
    let out = await pdfApi().compose(srcArr, pages);
    const perPage = ids.map((id) => annots.get(id) ?? []);
    if (perPage.some((a) => a.length)) out = await pdfApi().drawAnnotations(toAB(out), perPage);
    return out;
  }

  // Render the current edited document's pages to PNG/JPG and download (a zip
  // when there's more than one page). Rendering is pdf.js on the main thread.
  async function exportImages(format: 'png' | 'jpg', longPx: number) {
    const ids = orderedIds();
    if (ids.length === 0) return;
    setStatus('Rendering images…');
    let doc: ThumbDoc | null = null;
    try {
      const composed = await composeBaked(ids);
      doc = await openForThumbs(toAB(composed));
      const mime = format === 'png' ? 'image/png' : 'image/jpeg';
      const pad = String(doc.pageCount).length;
      const canvas = document.createElement('canvas');
      const entries: { name: string; bytes: Uint8Array }[] = [];
      for (let i = 0; i < doc.pageCount; i++) {
        await doc.render(i, canvas, longPx, 0);
        const blob: Blob = await new Promise((res, rej) =>
          canvas.toBlob((b) => (b ? res(b) : rej(new Error('Could not encode image'))), mime, 0.92),
        );
        entries.push({ name: `${baseName()}-${String(i + 1).padStart(pad, '0')}.${format}`, bytes: new Uint8Array(await blob.arrayBuffer()) });
        setStatus(`Rendering images… ${i + 1}/${doc.pageCount}`);
      }
      if (entries.length === 1) {
        download(entries[0]!.bytes, entries[0]!.name, mime);
      } else {
        const zip = await pdfApi().zipFiles(entries);
        download(zip, `${baseName()}-images.zip`, 'application/zip');
      }
      setStatus(`Exported ${entries.length} image${entries.length === 1 ? '' : 's'} — your download should start automatically.`, 'ok');
    } catch (e) {
      console.error(e);
      setStatus(shortError(e), 'err');
    } finally {
      doc?.destroy();
    }
  }

  // Bake the current edits into one PDF, run a transform, and reload it so the
  // result is visible and further editing continues on the stamped document.
  async function applyTransform(fn: (bytes: ArrayBuffer) => Promise<Uint8Array>, doneMsg: string) {
    const ids = orderedIds();
    if (ids.length === 0) return;
    setStatus('Applying…');
    try {
      const composed = await composeBaked(ids);
      const stamped = await fn(toAB(composed));
      if (await installSingleSource(toAB(stamped), fileName, false)) setStatus(doneMsg, 'ok');
    } catch (e) {
      console.error(e);
      setStatus(shortError(e), 'err');
    }
  }

  function appendSourcePages(sid: string, count: number): string[] {
    const frag = document.createDocumentFragment();
    const ids: string[] = [];
    for (let i = 0; i < count; i++) {
      const id = newId('p');
      ids.push(id);
      state.set(id, { sourceId: sid, src: i, rotate: 0 });
      frag.appendChild(buildTile(id));
    }
    rail.appendChild(frag);
    renumber();
    refreshSelectionUI();
    ids.slice(0, 8).forEach((id) => { rendered.add(id); queueRender(id); });
    return ids;
  }

  async function addFiles(files: File[]) {
    if (sources.size === 0) { await loadFile(files[0]!); files = files.slice(1); if (!files.length) return; }
    const isPdf = (f: File) => f.type === 'application/pdf' || f.name.toLowerCase().endsWith('.pdf');
    const isImg = (f: File) => /image\/(jpeg|png)/.test(f.type) || /\.(jpe?g|png)$/i.test(f.name);
    const pdfs = files.filter(isPdf);
    const imgs = files.filter(isImg);
    if (pdfs.length === 0 && imgs.length === 0) { setStatus('Add PDF or JPG/PNG files.', 'err'); return; }

    let added = 0;
    setStatus('Adding…');
    let firstNew: string | null = null;
    const ingest = async (buf: ArrayBuffer, label: string) => {
      const info = await pdfApi().analyze(buf.slice(0));
      if (info.encrypted || info.pages === 0) { setStatus(`Skipped ${label} (encrypted or damaged).`, 'err'); return; }
      const doc = await openForThumbs(buf.slice(0));
      const sid = newId('s');
      sources.set(sid, { bytes: buf, doc });
      const ids = appendSourcePages(sid, doc.pageCount);
      if (!firstNew && ids[0]) firstNew = ids[0];
      added += doc.pageCount;
    };

    try {
      for (const f of pdfs) await ingest(await f.arrayBuffer(), f.name);
      if (imgs.length) {
        const items = await Promise.all(
          imgs.map(async (f) => ({
            name: f.name,
            kind: (f.type === 'image/png' || /\.png$/i.test(f.name) ? 'png' : 'jpg') as 'png' | 'jpg',
            bytes: await f.arrayBuffer(),
          })),
        );
        const out = await pdfApi().imagesToPdf(items);
        const ab = new ArrayBuffer(out.byteLength);
        new Uint8Array(ab).set(out);
        await ingest(ab, `${imgs.length} image${imgs.length === 1 ? '' : 's'}`);
      }
      if (added > 0) {
        if (firstNew) { setActive(firstNew); selectOnly(firstNew); }
        setStatus(`Added ${added} page${added === 1 ? '' : 's'}.`, 'ok');
      }
    } catch (e) {
      console.error(e);
      setStatus(shortError(e), 'err');
    }
  }

  // wiring
  pickBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => { const f = fileInput.files?.[0]; if (f) loadFile(f); });
  addBtn.addEventListener('click', () => addInput.click());
  addInput.addEventListener('change', () => { const fs = addInput.files; if (fs && fs.length) addFiles([...fs]); addInput.value = ''; });
  resetBtn.addEventListener('click', reset);
  selectAllBtn.addEventListener('click', () => {
    selected.clear();
    for (const id of orderedIds()) selected.add(id);
    anchor = orderedIds()[0] ?? null;
    refreshSelectionUI();
  });
  clearSelBtn.addEventListener('click', () => { selected.clear(); anchor = null; refreshSelectionUI(); });
  rotLBtn.addEventListener('click', () => rotateIds(targetIds(), -90));
  rotRBtn.addEventListener('click', () => rotateIds(targetIds(), 90));
  dupBtn.addEventListener('click', () => duplicateIds(targetIds()));
  delBtn.addEventListener('click', () => deleteIds(targetIds()));
  extractBtn.addEventListener('click', () => exportPages(selectedOrdered(), 'extract', 'Extracted selected pages'));
  downloadBtn.addEventListener('click', () => exportPages(orderedIds(), 'edited', 'Done'));

  // contextual tool panel (right side): page numbers / watermark / export images
  const studioEl = $('studio');
  const toolPanel = $('toolPanel');
  const tpSections = [...toolPanel.querySelectorAll<HTMLElement>('.tp-section')];
  let curTool: '' | 'num' | 'wm' | 'img' | 'ann' | 'sign' = '';
  function showPanel(which: '' | 'num' | 'wm' | 'img' | 'ann' | 'sign') {
    curTool = which;
    const open = which !== '';
    toolPanel.hidden = !open;
    studioEl.classList.toggle('panel-open', open);
    annotateMode = which === 'ann';
    // The Sign panel also needs overlay pointer events (to stamp / select / drag).
    const signing = which === 'sign';
    studioEl.classList.toggle('annotating', annotateMode || signing);
    if (!signing) { placingSig = false; drag = null; selAnnot = null; annotCanvas.style.cursor = 'default'; }
    for (const s of tpSections) s.hidden = s.dataset.tp !== which;
    renderBig(); // stage width changed — re-fit the page
  }
  $('annBtn').addEventListener('click', () => showPanel(curTool === 'ann' ? '' : 'ann'));
  $('signBtn').addEventListener('click', () => showPanel(curTool === 'sign' ? '' : 'sign'));
  $('numBtn').addEventListener('click', () => showPanel(curTool === 'num' ? '' : 'num'));
  $('wmBtn').addEventListener('click', () => showPanel(curTool === 'wm' ? '' : 'wm'));
  $('imgBtn').addEventListener('click', () => showPanel(curTool === 'img' ? '' : 'img'));
  toolPanel.querySelectorAll('[data-close]').forEach((b) => b.addEventListener('click', () => showPanel('')));
  $('warnDismiss').addEventListener('click', () => { warnEl.hidden = true; });

  // ---------- Signature creator (draw / type / upload) ----------
  const sigPad = $('sigPad') as HTMLCanvasElement;
  const sigPadCtx = sigPad.getContext('2d');
  const sigTypePreview = $('sigTypePreview') as HTMLCanvasElement;
  const sigUploadPreview = $('sigUploadPreview') as HTMLCanvasElement;
  const sigText = $('sigText') as HTMLInputElement;
  const sigFont = $('sigFont') as HTMLSelectElement;
  let sigDrawing = false;

  function setSigMode(m: typeof sigMode, btn?: HTMLElement) {
    sigMode = m;
    const target = btn ?? document.querySelector<HTMLElement>('[data-sigmode="' + m + '"]');
    document.querySelectorAll<HTMLElement>('[data-sigmode]').forEach((x) => x.classList.toggle('active', x === target));
    $('sigDrawWrap').hidden = m !== 'draw';
    $('sigTypeWrap').hidden = m !== 'type';
    $('sigUploadWrap').hidden = m !== 'upload';
  }
  document.querySelectorAll<HTMLElement>('[data-sigmode]').forEach((b) =>
    b.addEventListener('click', () => setSigMode((b.dataset.sigmode as typeof sigMode) ?? 'draw', b)));

  // Trim transparent margins; return a tight crop canvas (or null if blank).
  function trimTransparent(src: HTMLCanvasElement): { canvas: HTMLCanvasElement; w: number; h: number } | null {
    const ctx = src.getContext('2d'); if (!ctx) return null;
    const { width, height } = src;
    const d = ctx.getImageData(0, 0, width, height).data;
    let mnx = width, mny = height, mxx = -1, mxy = -1;
    for (let y = 0; y < height; y++) for (let x = 0; x < width; x++) {
      if (d[(y * width + x) * 4 + 3]! > 8) { if (x < mnx) mnx = x; if (x > mxx) mxx = x; if (y < mny) mny = y; if (y > mxy) mxy = y; }
    }
    if (mxx < mnx || mxy < mny) return null;
    const pad = 6, w = mxx - mnx + 1 + pad * 2, h = mxy - mny + 1 + pad * 2;
    const out = document.createElement('canvas'); out.width = w; out.height = h;
    out.getContext('2d')!.drawImage(src, mnx - pad, mny - pad, w, h, 0, 0, w, h);
    return { canvas: out, w, h };
  }
  function canvasToPngBytes(c: HTMLCanvasElement): Promise<Uint8Array> {
    return new Promise((res, rej) => c.toBlob(async (b) => {
      if (!b) { rej(new Error('encode failed')); return; }
      res(new Uint8Array(await b.arrayBuffer()));
    }, 'image/png'));
  }
  async function finalizeSig(src: HTMLCanvasElement, trim: boolean) {
    const cropped = trim ? trimTransparent(src) : { canvas: src, w: src.width, h: src.height };
