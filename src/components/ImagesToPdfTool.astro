---
// Images -> PDF tool. Interactive logic is the <script> island; it runs in the
// browser and calls the PDF Web Worker (pdfClient). Nothing is uploaded.
const STORE_URL = 'https://apps.microsoft.com/detail/9MV6R84RVKCZ';
---

<section class="images-tool">
  <div id="dropzone" class="dropzone">
    <h3>Drop images here</h3>
    <p class="muted" style="margin: 4px 0 14px;">or</p>
    <button type="button" id="pickBtn" class="btn btn-ghost">Choose images</button>
    <input
      id="fileInput"
      type="file"
      accept="image/jpeg,image/png,.jpg,.jpeg,.png"
      multiple
      class="visually-hidden"
      tabindex="-1"
      aria-hidden="true"
    />
    <p class="muted" style="margin-top: 14px; font-size: 13px;">
      JPG and PNG — one image per page, in the order shown below.
    </p>
  </div>

  <div id="grid" class="imggrid" aria-label="Images to convert, in order"></div>

  <div class="actions-row" id="actions" hidden>
    <button id="runBtn" class="btn btn-primary" disabled>Create PDF &amp; download</button>
    <button id="clearBtn" class="btn btn-ghost">Clear all</button>
  </div>

  <p id="status" class="status" role="status" aria-live="polite"></p>

  <div class="trust">
    <strong>100% private.</strong> Your images become a PDF right here in your browser —
    they are never uploaded to a server.
  </div>

  <p class="upsell muted" style="font-size: 13.5px;">
    Need OCR, redaction, or to edit text?
    <a href={STORE_URL} target="_blank" rel="noopener">Get the free DocLab desktop app →</a>
  </p>
</section>

<script>
  import { pdfApi } from '../lib/pdfClient';

  interface Item {
    id: string;
    name: string;
    kind: 'jpg' | 'png';
    bytes: ArrayBuffer;
    url: string;
  }

  const dropzone = document.getElementById('dropzone')!;
  const pickBtn = document.getElementById('pickBtn') as HTMLButtonElement;
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const gridEl = document.getElementById('grid')!;
  const actions = document.getElementById('actions')!;
  const runBtn = document.getElementById('runBtn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clearBtn') as HTMLButtonElement;
  const statusEl = document.getElementById('status')!;

  let items: Item[] = [];

  function setStatus(msg: string, kind: '' | 'ok' | 'err' = '') {
    statusEl.textContent = msg;
    statusEl.className = 'status' + (kind ? ' ' + kind : '');
  }

  function iconButton(label: string, aria: string, onClick: () => void): HTMLButtonElement {
    const b = document.createElement('button');
    b.type = 'button';
    b.className = 'btn-icon';
    b.textContent = label;
    b.setAttribute('aria-label', aria);
    b.addEventListener('click', onClick);
    return b;
  }

  function render() {
    gridEl.replaceChildren();
    items.forEach((item, idx) => {
      const card = document.createElement('div');
      card.className = 'imgcard';

      const badge = document.createElement('span');
      badge.className = 'idx';
      badge.textContent = String(idx + 1);

      const img = document.createElement('img');
      img.src = item.url;
      img.alt = item.name;
      img.loading = 'lazy';

      const cap = document.createElement('div');
      cap.className = 'cap';
      const nm = document.createElement('span');
      nm.className = 'nm';
      nm.textContent = item.name;
      nm.title = item.name;

      const ctl = document.createElement('div');
      ctl.className = 'ctl';
      const up = iconButton('↑', `Move ${item.name} earlier`, () => move(idx, -1));
      up.disabled = idx === 0;
      const down = iconButton('↓', `Move ${item.name} later`, () => move(idx, 1));
      down.disabled = idx === items.length - 1;
      const rm = iconButton('✕', `Remove ${item.name}`, () => remove(item.id));
      ctl.append(up, down, rm);

      cap.append(nm, ctl);
      card.append(badge, img, cap);
      gridEl.appendChild(card);
    });
    actions.hidden = items.length === 0;
    runBtn.disabled = items.length === 0;
  }

  function move(idx: number, dir: number) {
    const j = idx + dir;
    if (j < 0 || j >= items.length) return;
    const tmp = items[idx]!;
    items[idx] = items[j]!;
    items[j] = tmp;
    render();
  }

  function remove(id: string) {
    const it = items.find((i) => i.id === id);
    if (it) URL.revokeObjectURL(it.url);
    items = items.filter((i) => i.id !== id);
    render();
    if (items.length === 0) setStatus('');
  }

  function clearAll() {
    for (const it of items) URL.revokeObjectURL(it.url);
    items = [];
    render();
    setStatus('');
  }

  async function addFiles(files: FileList | File[]) {
    const imgs = Array.from(files).filter((f) => {
      const n = f.name.toLowerCase();
      return (
        f.type === 'image/jpeg' ||
        f.type === 'image/png' ||
        n.endsWith('.jpg') ||
        n.endsWith('.jpeg') ||
        n.endsWith('.png')
      );
    });
    if (imgs.length === 0) {
      setStatus('Please choose JPG or PNG images.', 'err');
      return;
    }
    setStatus('');
    for (const f of imgs) {
      const bytes = await f.arrayBuffer();
      const n = f.name.toLowerCase();
      const kind: 'jpg' | 'png' = f.type === 'image/png' || n.endsWith('.png') ? 'png' : 'jpg';
      items.push({
        id: crypto.randomUUID(),
        name: f.name,
        kind,
        bytes,
        url: URL.createObjectURL(f),
      });
    }
    render();
  }

  async function run() {
    if (items.length === 0) return;
    runBtn.disabled = true;
    setStatus('Building PDF…');
    try {
      const bytes = await pdfApi().imagesToPdf(
        items.map((i) => ({ name: i.name, kind: i.kind, bytes: i.bytes.slice(0) })),
      );
      const buf = new ArrayBuffer(bytes.byteLength);
      new Uint8Array(buf).set(bytes);
      const url = URL.createObjectURL(new Blob([buf], { type: 'application/pdf' }));
      const a = document.createElement('a');
      a.href = url;
      a.download = 'doclab-images.pdf';
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 5000);
      setStatus(
        `Done — ${items.length} image${items.length === 1 ? '' : 's'} into one PDF. Your download should start automatically.`,
        'ok',
      );
    } catch (e) {
      console.error(e);
      setStatus('Could not build the PDF. Some images may be unsupported — try the desktop app.', 'err');
    } finally {
      runBtn.disabled = items.length === 0;
    }
  }

  pickBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => {
    if (fileInput.files) addFiles(fileInput.files);
    fileInput.value = '';
  });
  runBtn.addEventListener('click', run);
  clearBtn.addEventListener('click', clearAll);

  (['dragenter', 'dragover'] as const).forEach((ev) =>
    dropzone.addEventListener(ev, (e) => {
      e.preventDefault();
      dropzone.classList.add('drag');
    }),
  );
  (['dragleave', 'drop'] as const).forEach((ev) =>
    dropzone.addEventListener(ev, (e) => {
      e.preventDefault();
      dropzone.classList.remove('drag');
    }),
  );
  dropzone.addEventListener('drop', (e) => {
    const dt = (e as DragEvent).dataTransfer;
    if (dt?.files) addFiles(dt.files);
  });
</script>
