---
// Organize PDF workspace: pdf.js thumbnails + drag-to-reorder + per-page
// rotate/delete. The interactive logic is the <script> island below. Page
// previews render with pdf.js (main thread); the final edited PDF is built by
// the pdf-lib Web Worker (full fidelity). Nothing is uploaded.
const STORE_URL = 'https://apps.microsoft.com/detail/9MV6R84RVKCZ';
---

<section class="organize-tool">
  <div id="dropzone" class="dropzone">
    <h3>Drop a PDF here</h3>
    <p class="muted" style="margin: 4px 0 14px;">or</p>
    <button type="button" id="pickBtn" class="btn btn-ghost">Choose a PDF</button>
    <input id="fileInput" type="file" accept="application/pdf,.pdf" class="visually-hidden" tabindex="-1" aria-hidden="true" />
    <p class="muted" style="margin-top: 14px; font-size: 13px;">
      Reorder by dragging, rotate or delete any page, then download the result.
    </p>
  </div>

  <div id="workspace" hidden>
    <div class="filerow" style="margin: 22px 0 0;">
      <div class="meta">
        <div class="name" id="fileName"></div>
        <div class="sub" id="fileSub"></div>
      </div>
      <button type="button" id="resetBtn" class="btn-icon" aria-label="Choose a different file">✕</button>
    </div>

    <p id="warn" class="warn" hidden style="margin-top: 14px;"></p>

    <div class="org-toolbar">
      <span class="count" id="count"></span>
      <button type="button" id="rotateAllBtn" class="btn btn-ghost btn-sm">Rotate all ⟳</button>
      <button type="button" id="revertBtn" class="btn btn-ghost btn-sm">Revert</button>
      <button type="button" id="applyBtn" class="btn btn-primary btn-sm">Apply changes &amp; download</button>
    </div>
    <p class="org-hint">Drag pages to reorder. Use the buttons on each page to rotate, delete, or nudge left/right.</p>

    <div id="grid" class="pgrid" aria-label="Pages — drag to reorder"></div>
  </div>

  <p id="status" class="status" role="status" aria-live="polite"></p>

  <div class="trust"><strong>100% private.</strong> Pages are previewed and rearranged right here in your browser — your PDF is never uploaded.</div>
  <p class="upsell muted" style="font-size: 13.5px;">
    Need OCR, redaction, or to edit text? <a href={STORE_URL} target="_blank" rel="noopener">Get the free DocLab desktop app →</a>
  </p>
</section>

<script>
  import { pdfApi } from '../lib/pdfClient';
  import { openForThumbs, type ThumbDoc } from '../lib/pdfThumbs';

  const THUMB_PX = 220;

  const dropzone = document.getElementById('dropzone')!;
  const pickBtn = document.getElementById('pickBtn') as HTMLButtonElement;
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const workspace = document.getElementById('workspace')!;
  const fileNameEl = document.getElementById('fileName')!;
  const fileSubEl = document.getElementById('fileSub')!;
  const warnEl = document.getElementById('warn')!;
  const countEl = document.getElementById('count')!;
  const grid = document.getElementById('grid')!;
  const applyBtn = document.getElementById('applyBtn') as HTMLButtonElement;
  const revertBtn = document.getElementById('revertBtn') as HTMLButtonElement;
  const rotateAllBtn = document.getElementById('rotateAllBtn') as HTMLButtonElement;
  const resetBtn = document.getElementById('resetBtn') as HTMLButtonElement;
  const statusEl = document.getElementById('status')!;

  interface Tile { src: number; rotate: number; }

  let bytes: ArrayBuffer | null = null;
  let fileName = '';
  let thumbDoc: ThumbDoc | null = null;
  const state = new Map<string, Tile>();
  const els = new Map<string, HTMLElement>();
  const rendered = new Set<string>();
  let renderChain: Promise<void> = Promise.resolve();
  let observer: IntersectionObserver | null = null;

  function setStatus(msg: string, kind: '' | 'ok' | 'err' = '') {
    statusEl.textContent = msg;
    statusEl.className = 'status' + (kind ? ' ' + kind : '');
  }
  function shortError(e: unknown): string {
    const s = e instanceof Error ? e.message : String(e);
    return s.length > 160 ? s.slice(0, 159) + '…' : s;
  }

  function iconButton(label: string, aria: string, cls: string, onClick: () => void): HTMLButtonElement {
    const b = document.createElement('button');
    b.type = 'button';
    b.className = 'btn-icon' + (cls ? ' ' + cls : '');
    b.textContent = label;
    b.title = aria;
    b.setAttribute('aria-label', aria);
    b.addEventListener('click', (e) => { e.stopPropagation(); onClick(); });
    b.setAttribute('draggable', 'false');
    return b;
  }

  function tileCount(): number {
    return grid.querySelectorAll('.ptile').length;
  }

  function renumber() {
    const tiles = grid.querySelectorAll<HTMLElement>('.ptile');
    tiles.forEach((t, i) => {
      const pos = t.querySelector('.pos');
      if (pos) pos.textContent = String(i + 1);
    });
    const n = tiles.length;
    countEl.textContent = `${n} page${n === 1 ? '' : 's'}`;
    applyBtn.disabled = n === 0;
  }

  function updateRotBadge(id: string) {
    const el = els.get(id);
    const s = state.get(id);
    if (!el || !s) return;
    const badge = el.querySelector('.rotbadge') as HTMLElement | null;
    if (!badge) return;
    const r = ((s.rotate % 360) + 360) % 360;
    if (r === 0) badge.hidden = true;
    else { badge.hidden = false; badge.textContent = `${r}°`; }
  }

  function queueRender(id: string) {
    renderChain = renderChain.then(async () => {
      const el = els.get(id);
      const s = state.get(id);
      if (!el || !s || !thumbDoc) return;
      const canvas = el.querySelector('canvas') as HTMLCanvasElement | null;
      if (!canvas) return;
      try {
        await thumbDoc.render(s.src, canvas, THUMB_PX, s.rotate);
        el.classList.add('thumb-ready');
      } catch (e) {
        // Leave the numbered placeholder visible; a missing preview never
        // affects the exported PDF (that's pdf-lib, full fidelity).
        el.classList.remove('thumb-ready');
        console.error('[thumb render]', e);
      }
    });
  }

  function buildTile(id: string): HTMLElement {
    const s = state.get(id)!;
    const el = document.createElement('div');
    el.className = 'ptile';
    el.dataset.id = id;
    el.setAttribute('draggable', 'true');

    const pos = document.createElement('span');
    pos.className = 'pos';

    const rot = document.createElement('span');
    rot.className = 'rotbadge';
    rot.hidden = true;

    const thumb = document.createElement('div');
    thumb.className = 'thumb';
    const canvas = document.createElement('canvas');
    const ph = document.createElement('span');
    ph.className = 'ph';
    ph.textContent = `Page ${s.src + 1}`;
    thumb.append(canvas, ph);

    const bar = document.createElement('div');
    bar.className = 'tilebar';
    bar.append(
      iconButton('←', 'Move left', '', () => move(id, -1)),
      iconButton('⟲', 'Rotate left', '', () => rotate(id, -90)),
      iconButton('⟳', 'Rotate right', '', () => rotate(id, 90)),
      iconButton('🗑', 'Delete page', 'danger', () => remove(id)),
      iconButton('→', 'Move right', '', () => move(id, 1)),
    );

    el.append(pos, rot, thumb, bar);
    els.set(id, el);

    // Lazy-render when scrolled into view.
    observer?.observe(el);

    // Drag to reorder.
    el.addEventListener('dragstart', (e) => {
      el.classList.add('dragging');
      (e as DragEvent).dataTransfer?.setData('text/plain', id);
      if ((e as DragEvent).dataTransfer) (e as DragEvent).dataTransfer!.effectAllowed = 'move';
    });
    el.addEventListener('dragend', () => {
      el.classList.remove('dragging');
      renumber();
    });

    return el;
  }

  function getDragAfter(x: number, y: number): Element | null {
    const tiles = [...grid.querySelectorAll('.ptile:not(.dragging)')];
    let closest: Element | null = null;
    let closestDist = Infinity;
    let before = true;
    for (const t of tiles) {
      const r = t.getBoundingClientRect();
      const cx = r.left + r.width / 2;
      const cy = r.top + r.height / 2;
      const d = Math.hypot(x - cx, y - cy);
      if (d < closestDist) {
        closestDist = d;
        closest = t;
        before = x < cx;
      }
    }
    if (!closest) return null;
    return before ? closest : closest.nextElementSibling;
  }

  grid.addEventListener('dragover', (e) => {
    e.preventDefault();
    const dragging = grid.querySelector('.ptile.dragging') as HTMLElement | null;
    if (!dragging) return;
    if ((e as DragEvent).dataTransfer) (e as DragEvent).dataTransfer!.dropEffect = 'move';
    const after = getDragAfter((e as DragEvent).clientX, (e as DragEvent).clientY);
    if (after == null) grid.appendChild(dragging);
    else if (after !== dragging) grid.insertBefore(dragging, after);
  });
  grid.addEventListener('drop', (e) => e.preventDefault());

  function move(id: string, dir: number) {
    const el = els.get(id);
    if (!el) return;
    if (dir < 0) {
      const prev = el.previousElementSibling;
      if (prev) grid.insertBefore(el, prev);
    } else {
      const next = el.nextElementSibling;
      if (next) grid.insertBefore(next, el);
    }
    renumber();
    (el.querySelector(dir < 0 ? '[aria-label="Move left"]' : '[aria-label="Move right"]') as HTMLElement | null)?.focus();
  }

  function rotate(id: string, delta: number) {
    const s = state.get(id);
    if (!s) return;
    s.rotate = (((s.rotate + delta) % 360) + 360) % 360;
    updateRotBadge(id);
    queueRender(id);
  }

  function remove(id: string) {
    if (tileCount() <= 1) {
      setStatus('Keep at least one page.', 'err');
      return;
    }
    const el = els.get(id);
    if (el) { observer?.unobserve(el); el.remove(); }
    els.delete(id);
    state.delete(id);
    rendered.delete(id);
    renumber();
    setStatus('');
  }

  function rotateAll() {
    for (const id of els.keys()) rotate(id, 90);
  }

  function teardown() {
    observer?.disconnect();
    observer = null;
    thumbDoc?.destroy();
    thumbDoc = null;
    state.clear();
    els.clear();
    rendered.clear();
    grid.replaceChildren();
    renderChain = Promise.resolve();
  }

  function reset() {
    teardown();
    bytes = null;
    fileName = '';
    workspace.hidden = true;
    dropzone.hidden = false;
    warnEl.hidden = true;
    fileInput.value = '';
    setStatus('');
  }

  async function loadFile(file: File) {
    if (file.type !== 'application/pdf' && !file.name.toLowerCase().endsWith('.pdf')) {
      setStatus('Please choose a PDF file.', 'err');
      return;
    }
    teardown();
    setStatus('Opening…');
    const buf = await file.arrayBuffer();
    const info = await pdfApi().analyze(buf.slice(0));
    if (info.encrypted || info.pages === 0) {
      setStatus("Can't open this PDF (encrypted or damaged) — try the desktop app.", 'err');
      return;
    }
    let doc: ThumbDoc;
    try {
      doc = await openForThumbs(buf.slice(0));
    } catch (e) {
      console.error(e);
      setStatus("Couldn't read this PDF for preview — try the desktop app.", 'err');
      return;
    }

    bytes = buf;
    fileName = file.name;
    thumbDoc = doc;
    fileNameEl.textContent = file.name;
    fileSubEl.textContent = `${doc.pageCount} page${doc.pageCount === 1 ? '' : 's'}`;
    warnEl.hidden = !info.tagged;
    if (info.tagged) {
      warnEl.textContent =
        'Heads up: this PDF is tagged for accessibility. Reorganizing it here may drop those tags — for accessibility-preserving edits, use the DocLab desktop app.';
    }

    observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const id = (entry.target as HTMLElement).dataset.id;
          if (id && !rendered.has(id)) {
            rendered.add(id);
            queueRender(id);
          }
        }
      },
      { root: null, rootMargin: '300px' },
    );

    const frag = document.createDocumentFragment();
    const ids: string[] = [];
    for (let i = 0; i < doc.pageCount; i++) {
      const id = `p${i}-${crypto.randomUUID().slice(0, 8)}`;
      ids.push(id);
      state.set(id, { src: i, rotate: 0 });
      frag.appendChild(buildTile(id));
    }
    grid.appendChild(frag);
    renumber();

    // Eager-render the first screenful so thumbnails appear immediately; the
    // IntersectionObserver renders the rest as they scroll into view.
    ids.slice(0, 12).forEach((id) => {
      rendered.add(id);
      queueRender(id);
    });

    dropzone.hidden = true;
    workspace.hidden = false;
    setStatus('');
  }

  async function apply() {
    if (!bytes) return;
    const order = [...grid.querySelectorAll<HTMLElement>('.ptile')];
    if (order.length === 0) {
      setStatus('Keep at least one page.', 'err');
      return;
    }
    const ops = order.map((el) => {
      const s = state.get(el.dataset.id ?? '');
      return { index: s?.src ?? 0, rotate: s?.rotate ?? 0 };
    });
    applyBtn.disabled = true;
    setStatus('Building your PDF…');
    try {
      const out = await pdfApi().organize(bytes.slice(0), ops);
      const ab = new ArrayBuffer(out.byteLength);
      new Uint8Array(ab).set(out);
      const url = URL.createObjectURL(new Blob([ab], { type: 'application/pdf' }));
      const a = document.createElement('a');
      a.href = url;
      a.download = `${fileName.replace(/\.pdf$/i, '') || 'document'}-organized.pdf`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 5000);
      setStatus('Done — your download should start automatically.', 'ok');
    } catch (e) {
      console.error(e);
      setStatus(shortError(e), 'err');
    } finally {
      applyBtn.disabled = tileCount() === 0;
    }
  }

  pickBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => {
    const f = fileInput.files?.[0];
    if (f) loadFile(f);
  });
  applyBtn.addEventListener('click', apply);
  rotateAllBtn.addEventListener('click', rotateAll);
  revertBtn.addEventListener('click', () => {
    const f = fileInput.files?.[0];
    if (bytes && f) loadFile(f);
  });
  resetBtn.addEventListener('click', reset);

  (['dragenter', 'dragover'] as const).forEach((ev) =>
    dropzone.addEventListener(ev, (e) => {
      e.preventDefault();
      dropzone.classList.add('drag');
    }),
  );
  (['dragleave', 'drop'] as const).forEach((ev) =>
    dropzone.addEventListener(ev, (e) => {
      e.preventDefault();
      dropzone.classList.remove('drag');
    }),
  );
  dropzone.addEventListener('drop', (e) => {
    const f = (e as DragEvent).dataTransfer?.files?.[0];
    if (f) loadFile(f);
  });
</script>
