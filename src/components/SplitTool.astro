---
// Split tool UI. Interactive logic is the <script> island below; it calls the
// PDF Web Worker (pdfClient). Nothing is uploaded.
const STORE_URL = 'https://apps.microsoft.com/detail/9MV6R84RVKCZ';
---

<section class="split-tool">
  <div id="dropzone" class="dropzone">
    <h3>Drop a PDF here</h3>
    <p class="muted" style="margin: 4px 0 14px;">or</p>
    <button type="button" id="pickBtn" class="btn btn-ghost">Choose a PDF</button>
    <input id="fileInput" type="file" accept="application/pdf,.pdf" class="visually-hidden" tabindex="-1" aria-hidden="true" />
  </div>

  <div id="controls" hidden style="margin-top: 22px;">
    <div class="filerow" style="margin-bottom: 16px;">
      <div class="meta">
        <div class="name" id="fileName"></div>
        <div class="sub" id="fileSub"></div>
      </div>
      <button type="button" id="resetBtn" class="btn-icon" aria-label="Choose a different file">✕</button>
    </div>

    <p id="warn" class="warn" hidden></p>

    <fieldset>
      <legend>How to split</legend>
      <div class="rot-group" role="radiogroup" aria-label="Split mode">
        <label class="rot"><input type="radio" name="mode" value="each" checked /> Each page → its own file</label>
        <label class="rot"><input type="radio" name="mode" value="ranges" /> Custom ranges</label>
        <label class="rot"><input type="radio" name="mode" value="every" /> Every N pages</label>
      </div>
    </fieldset>

    <div id="rangesCtl" hidden style="margin-bottom: 16px;">
      <label for="rangeInput" style="display: block; font-size: 14px; margin-bottom: 6px;">Ranges (one file per group)</label>
      <input id="rangeInput" type="text" class="text-input" style="width: 100%;" placeholder="e.g. 1-3, 4-8, 9-" autocomplete="off" />
      <p class="muted" style="font-size: 12.5px; margin: 6px 0 0;">Each comma-separated group becomes one PDF. <code>1-3, 4-8</code> → two files.</p>
    </div>

    <div id="everyCtl" hidden style="margin-bottom: 16px;">
      <label for="everyInput" style="display: block; font-size: 14px; margin-bottom: 6px;">Pages per file</label>
      <input id="everyInput" type="number" min="1" step="1" value="1" class="text-input" style="width: 120px;" />
    </div>

    <div class="actions-row">
      <button id="runBtn" class="btn btn-primary">Split &amp; download</button>
      <button id="clearBtn" type="button" class="btn btn-ghost">Start over</button>
    </div>
  </div>

  <p id="status" class="status" role="status" aria-live="polite"></p>

  <div class="trust"><strong>100% private.</strong> Your PDF is split right here in your browser — it is never uploaded.</div>
  <p class="upsell muted" style="font-size: 13.5px;">
    Need OCR, redaction, or to edit text? <a href={STORE_URL} target="_blank" rel="noopener">Get the free DocLab desktop app →</a>
  </p>
</section>

<script>
  import { pdfApi } from '../lib/pdfClient';
  import { parsePageGroups, chunkPages } from '../lib/pageRange';

  const dropzone = document.getElementById('dropzone')!;
  const pickBtn = document.getElementById('pickBtn') as HTMLButtonElement;
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const controls = document.getElementById('controls')!;
  const fileNameEl = document.getElementById('fileName')!;
  const fileSubEl = document.getElementById('fileSub')!;
  const warnEl = document.getElementById('warn')!;
  const rangesCtl = document.getElementById('rangesCtl')!;
  const everyCtl = document.getElementById('everyCtl')!;
  const rangeInput = document.getElementById('rangeInput') as HTMLInputElement;
  const everyInput = document.getElementById('everyInput') as HTMLInputElement;
  const runBtn = document.getElementById('runBtn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clearBtn') as HTMLButtonElement;
  const resetBtn = document.getElementById('resetBtn') as HTMLButtonElement;
  const statusEl = document.getElementById('status')!;
  const root = document.querySelector('.split-tool') as HTMLElement;

  let bytes: ArrayBuffer | null = null;
  let fileName = '';
  let pageCount = 0;

  function setStatus(msg: string, kind: '' | 'ok' | 'err' = '') {
    statusEl.textContent = msg;
    statusEl.className = 'status' + (kind ? ' ' + kind : '');
  }
  function shortError(e: unknown): string {
    const s = e instanceof Error ? e.message : String(e);
    return s.length > 160 ? s.slice(0, 159) + '…' : s;
  }
  function currentMode(): 'each' | 'ranges' | 'every' {
    const c = root.querySelector('input[name="mode"]:checked') as HTMLInputElement | null;
    return (c?.value as 'each' | 'ranges' | 'every') ?? 'each';
  }
  function syncMode() {
    const m = currentMode();
    rangesCtl.hidden = m !== 'ranges';
    everyCtl.hidden = m !== 'every';
  }

  function reset() {
    bytes = null;
    fileName = '';
    pageCount = 0;
    controls.hidden = true;
    dropzone.hidden = false;
    warnEl.hidden = true;
    rangeInput.value = '';
    everyInput.value = '1';
    fileInput.value = '';
    setStatus('');
  }

  async function loadFile(file: File) {
    if (file.type !== 'application/pdf' && !file.name.toLowerCase().endsWith('.pdf')) {
      setStatus('Please choose a PDF file.', 'err');
      return;
    }
    setStatus('Reading…');
    const buf = await file.arrayBuffer();
    const info = await pdfApi().analyze(buf.slice(0));
    if (info.encrypted || info.pages === 0) {
      setStatus("Can't read this PDF (encrypted or damaged) — try the desktop app.", 'err');
      return;
    }
    bytes = buf;
    fileName = file.name;
    pageCount = info.pages;
    fileNameEl.textContent = file.name;
    fileSubEl.textContent = `${pageCount} page${pageCount === 1 ? '' : 's'}`;
    warnEl.hidden = !info.tagged;
    if (info.tagged) {
      warnEl.textContent =
        'Heads up: this PDF is tagged for accessibility. Splitting it here may drop those tags — for accessibility-preserving edits, use the DocLab desktop app.';
    }
    dropzone.hidden = true;
    controls.hidden = false;
    syncMode();
    setStatus('');
  }

  function download(out: Uint8Array, name: string, mime: string) {
    const ab = new ArrayBuffer(out.byteLength);
    new Uint8Array(ab).set(out);
    const url = URL.createObjectURL(new Blob([ab], { type: mime }));
    const a = document.createElement('a');
    a.href = url;
    a.download = name;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 5000);
  }

  async function run() {
    if (!bytes) return;
    let groups: number[][];
    try {
      const m = currentMode();
      if (m === 'each') {
        groups = Array.from({ length: pageCount }, (_, i) => [i]);
      } else if (m === 'ranges') {
        groups = parsePageGroups(rangeInput.value, pageCount);
      } else {
        groups = chunkPages(pageCount, Number(everyInput.value));
      }
    } catch (e) {
      setStatus(shortError(e), 'err');
      return;
    }
    runBtn.disabled = true;
    setStatus('Splitting…');
    try {
      const base = fileName.replace(/\.pdf$/i, '');
      const res = await pdfApi().splitPdf(bytes.slice(0), groups, base);
      download(res.bytes, res.filename, res.kind === 'zip' ? 'application/zip' : 'application/pdf');
      setStatus(
        res.kind === 'zip'
          ? `Done — ${res.parts} files zipped. Your download should start automatically.`
          : 'Done — your download should start automatically.',
        'ok',
      );
    } catch (e) {
      console.error(e);
      setStatus(shortError(e), 'err');
    } finally {
      runBtn.disabled = false;
    }
  }

  pickBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => {
    const f = fileInput.files?.[0];
    if (f) loadFile(f);
  });
  root.querySelectorAll('input[name="mode"]').forEach((el) => el.addEventListener('change', syncMode));
  runBtn.addEventListener('click', run);
  rangeInput.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') run();
  });
  clearBtn.addEventListener('click', reset);
  resetBtn.addEventListener('click', reset);

  (['dragenter', 'dragover'] as const).forEach((ev) =>
    dropzone.addEventListener(ev, (e) => {
      e.preventDefault();
      dropzone.classList.add('drag');
    }),
  );
  (['dragleave', 'drop'] as const).forEach((ev) =>
    dropzone.addEventListener(ev, (e) => {
      e.preventDefault();
      dropzone.classList.remove('drag');
    }),
  );
  dropzone.addEventListener('drop', (e) => {
    const f = (e as DragEvent).dataTransfer?.files?.[0];
    if (f) loadFile(f);
  });
</script>
