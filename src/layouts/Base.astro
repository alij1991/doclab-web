---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Optional JSON-LD structured-data objects rendered as <script type="application/ld+json">. */
  jsonLd?: unknown[];
}
const { title, description, jsonLd = [] } = Astro.props;
const STORE_URL = 'https://apps.microsoft.com/detail/9MV6R84RVKCZ';
// Self-referencing canonical + absolute OG image (Astro.site = https://doc-lab.net).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#5B5BD6" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="DocLab" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    {jsonLd.map((obj) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(obj)} />
    ))}
    {/* CSP is defense-in-depth here; the authoritative copy is public/_headers
        (Cloudflare). 'wasm-unsafe-eval' is reserved for the future pdf.js/WASM
        viewer — the merge tool needs none of it. */}
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'none'; form-action 'none'"
    />
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/"><img src="/icon.png" alt="" width="28" height="28" /> DocLab</a>
        <nav class="nav-links" aria-label="Primary">
          <a href="/#tools">Tools</a>
          <a href="/edit-pdf">Editor</a>
          <a href="/desktop">Desktop app</a>
          <a class="btn btn-primary btn-sm" href={STORE_URL} target="_blank" rel="noopener">Get it free</a>
        </nav>
      </div>
    </header>

    <main id="main"><slot /></main>

    <footer class="site-footer">
      <div class="container">
        <nav class="footer-tools" aria-label="PDF tools">
          <a href="/edit-pdf">Edit PDF</a>
          <a href="/merge-pdf">Merge PDF</a>
          <a href="/split-pdf">Split PDF</a>
          <a href="/rotate-pdf">Rotate PDF</a>
          <a href="/delete-pages">Delete pages</a>
          <a href="/extract-pages">Extract pages</a>
          <a href="/sign-pdf">Sign PDF</a>
          <a href="/watermark-pdf">Watermark</a>
          <a href="/add-page-numbers">Page numbers</a>
          <a href="/jpg-to-pdf">Images to PDF</a>
          <a href="/pdf-to-jpg">PDF to JPG</a>
          <a href="/pdf-to-png">PDF to PNG</a>
        </nav>
        <p><strong>Your files never leave your browser.</strong> Every tool runs entirely on your device — nothing is uploaded.</p>
        <p class="muted">
          <a href="/">Home</a> ·
          <a href="/edit-pdf">Editor</a> ·
          <a href="/desktop">Desktop app</a> ·
          <a href="/getting-started">Guide</a> ·
          <a href="/privacy">Privacy</a> ·
          <a href={STORE_URL} target="_blank" rel="noopener">Microsoft Store</a> ·
          <a href="https://github.com/alij1991/doclab-website/issues" target="_blank" rel="noopener">Support</a>
          <br />© 2026 Ali Javdani Rikhtehgar · DocLab is free; the web tools are open source.
        </p>
      </div>
    </footer>
  </body>
</html>
