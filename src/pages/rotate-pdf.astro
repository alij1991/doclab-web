---
import Base from '../layouts/Base.astro';
import EditorTool from '../components/EditorTool.astro';
---

<Base
  title="Rotate PDF — free & private | DocLab"
  description="Rotate PDF pages 90° or 180° while seeing every page, free and entirely in your browser. Your file is never uploaded."
>
  <section class="container tool-head">
    <p class="eyebrow"><a href="/" style="color: var(--brand); text-decoration: none;">← All tools</a></p>
    <h1>Rotate PDF</h1>
    <p class="lead">
      Open your PDF, see every page, and rotate the ones you need — left, right, or 180°. Then
      download. Runs in your browser; your file is never uploaded.
    </p>
  </section>

  <section class="container" style="padding-top: 8px;">
    <EditorTool />
  </section>
</Base>
