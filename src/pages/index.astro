---
import Base from '../layouts/Base.astro';

const STORE_URL = 'https://apps.microsoft.com/detail/9MV6R84RVKCZ';
const GITHUB_URL = 'https://github.com/alij1991/doclab-web';

// Brand entity for search engines / knowledge graph.
const orgJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'DocLab',
    url: 'https://doc-lab.net',
    logo: 'https://doc-lab.net/icon.png',
    description: 'Free, 100% in-browser PDF tools. Nothing is uploaded.',
    sameAs: ['https://apps.microsoft.com/detail/9MV6R84RVKCZ', 'https://github.com/alij1991/doclab-web'],
  },
  { '@context': 'https://schema.org', '@type': 'WebSite', name: 'DocLab', url: 'https://doc-lab.net' },
];

// Capabilities of the one editor — shown as an explanatory feature list, not
// separate destinations (every one of these happens inside /edit-pdf).
const tools = [
  { icon: '🗂️', title: 'Merge PDFs', desc: 'Add pages from other PDFs and combine them into one, in any order.' },
  { icon: '✂️', title: 'Split PDF', desc: 'Pull a range of pages out into a separate file.' },
  { icon: '🔄', title: 'Rotate pages', desc: 'Turn any page — or the whole document — the right way up.' },
  { icon: '🗑️', title: 'Delete pages', desc: 'Remove the pages you don’t need.' },
  { icon: '📄', title: 'Extract pages', desc: 'Keep just the pages you want as a new PDF.' },
  { icon: '🖼️', title: 'Images → PDF', desc: 'Drop in JPG / PNG photos and turn them into a PDF.' },
  { icon: '📸', title: 'PDF → images', desc: 'Export pages as PNG / JPG image files.' },
  { icon: '✎', title: 'Annotate', desc: 'Draw, highlight, add text and shapes, then move or resize them.' },
  { icon: '＃', title: 'Page numbers & watermark', desc: 'Stamp page numbers or a watermark across the document.' },
];
---

<Base
  title="DocLab — free, private PDF editor & tools (nothing uploaded)"
  description="A free visual PDF editor plus quick tools — edit, merge, split, rotate, organize, annotate, and convert PDFs right in your browser. No account, no limits, nothing uploaded."
  jsonLd={orgJsonLd}
>
  <section class="container hero">
    <p class="eyebrow">Free · Private · 100% in your browser</p>
    <h1>Edit & convert PDFs that <span class="grad">never leave your device</span></h1>
    <p class="lead" style="margin: 0 auto 28px;">
      One visual PDF editor that does it all — merge, split, rotate, organize, annotate,
      and convert, all in the same place. No account, no limits, and nothing is ever uploaded.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary btn-lg" href="/edit-pdf">Open the PDF editor →</a>
      <a class="btn btn-ghost btn-lg" href="#tools">See everything it does</a>
    </div>
    <div class="hero-badges">
      <span class="badge"><b>Free</b></span>
      <span class="badge"><b>No account</b></span>
      <span class="badge"><b>Nothing uploaded</b></span>
      <a class="badge" href={GITHUB_URL} target="_blank" rel="noopener"><b>Open source</b></a>
      <span class="badge">Windows · Mac · Linux · mobile</span>
    </div>
  </section>

  <section id="tools" class="container" style="padding-top: 32px;">
    <a class="feature-edit" href="/edit-pdf">
      <div class="fe-icon" aria-hidden="true">🛠️</div>
      <div style="flex: 1; min-width: 240px;">
        <p class="eyebrow" style="margin-bottom: 6px;">All-in-one editor</p>
        <h2 style="margin: 0 0 8px; font-size: 24px;">The full PDF editor — see every page, change anything</h2>
        <p class="muted" style="margin: 0;">
          Reorder, rotate, delete, duplicate, extract, add pages, annotate, number, watermark, and
          export — in one visual workspace with thumbnails of your whole document.
        </p>
      </div>
      <span class="btn btn-primary" style="flex-shrink: 0;">Open the editor →</span>
    </a>

    <p class="section-label">Everything the editor does</p>
    <p class="muted" style="margin: -8px 0 0; max-width: 620px;">
      It’s all one workspace — no separate pages to hunt through. Open the editor, load a PDF, and
      reach for whatever you need.
    </p>
    <div class="tool-grid">
      {
        tools.map((t) => (
          <div class="tool tool-static">
            <div class="ico">{t.icon}</div>
            <h3>{t.title}</h3>
            <p>{t.desc}</p>
          </div>
        ))
      }
    </div>
    <div class="tools-cta">
      <a class="btn btn-primary btn-lg" href="/edit-pdf">Open the editor to do any of these →</a>
    </div>
  </section>

  <section class="container" style="margin-top: 56px;">
    <div class="card promo">
      <div style="flex: 1; min-width: 260px;">
        <p class="eyebrow">Private by design</p>
        <h2 style="margin: 0 0 10px;">Your files stay yours</h2>
        <p class="muted" style="margin: 0;">
          Unlike most online PDF tools, DocLab runs entirely in your browser — there's no server,
          no upload, and no account. Your documents never leave your device.
        </p>
        <p class="muted" style="margin: 14px 0 0;">
          Don't just take our word for it — <a href={GITHUB_URL} target="_blank" rel="noopener" style="color: var(--brand);">the web tools are open source on GitHub</a>, so anyone can verify exactly what the code does.
        </p>
      </div>
      <div style="flex: 1; min-width: 260px;">
        <p class="muted" style="margin: 0 0 16px;">
          Need OCR, true redaction, or text editing? The free DocLab desktop app adds them — same
          privacy, more power.
        </p>
        <a class="btn btn-primary" href={STORE_URL} target="_blank" rel="noopener">Get the free desktop app →</a>
      </div>
    </div>
  </section>
</Base>
