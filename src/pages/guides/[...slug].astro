---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((g) => ({ params: { slug: g.id }, props: { g } }));
}

const { g } = Astro.props;
const { Content } = await render(g);

const site = 'https://doc-lab.net';
const url = `${site}/guides/${g.id}`;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: g.data.title,
    description: g.data.description,
    datePublished: g.data.pubDate.toISOString(),
    author: { '@type': 'Organization', name: 'DocLab', url: site },
    publisher: { '@type': 'Organization', name: 'DocLab', logo: { '@type': 'ImageObject', url: `${site}/icon.png` } },
    mainEntityOfPage: url,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: `${site}/guides` },
      { '@type': 'ListItem', position: 3, name: g.data.title, item: url },
    ],
  },
];
---

<Base title={`${g.data.title} | DocLab`} description={g.data.description} jsonLd={jsonLd}>
  <article class="container prose">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span aria-hidden="true">›</span>
      <a href="/guides">Guides</a> <span aria-hidden="true">›</span>
      <span aria-current="page">{g.data.title}</span>
    </nav>
    <h1>{g.data.title}</h1>
    <p class="muted" style="margin: -6px 0 18px; font-size: 14px;">{g.data.readMins} min read</p>
    <Content />
    <p style="margin-top: 28px;">
      <a class="btn btn-primary" href={g.data.tool}>{g.data.toolLabel} →</a>
    </p>
  </article>
</Base>
