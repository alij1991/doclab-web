---
import Base from '../layouts/Base.astro';
import EditorTool from '../components/EditorTool.astro';
---

<Base
  title="Delete PDF pages — free & private | DocLab"
  description="Remove pages from a PDF while seeing every page, free and entirely in your browser. Your file is never uploaded."
>
  <section class="container tool-head">
    <p class="eyebrow"><a href="/" style="color: var(--brand); text-decoration: none;">← All tools</a></p>
    <h1>Delete PDF pages</h1>
    <p class="lead">
      Open your PDF, see every page, select the ones you don't want, and delete them — then
      download the rest. Runs in your browser; your file is never uploaded.
    </p>
  </section>

  <section class="container" style="padding-top: 8px;">
    <EditorTool />
  </section>
</Base>
