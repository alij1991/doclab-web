---
import Base from '../layouts/Base.astro';
import PageOpTool from '../components/PageOpTool.astro';
---

<Base
  title="Delete PDF pages — free & private | DocLab"
  description="Remove pages from a PDF, free and entirely in your browser. Your file is never uploaded."
>
  <section class="container tool-head">
    <p class="eyebrow"><a href="/" style="color: var(--brand); text-decoration: none;">← All tools</a></p>
    <h1>Delete PDF pages</h1>
    <p class="lead">
      Remove the pages you don't need and download the rest. Runs in your browser; your file is
      never uploaded.
    </p>
  </section>

  <section class="container" style="padding-top: 8px;">
    <PageOpTool op="delete" />
  </section>
</Base>
